<div class="card shadow-sm border-0 m-2 transition-all hover-shadow" style="width: 19rem; display: inline-block; vertical-align: top; border-radius: 12px; background: #ffffff; overflow: hidden; border: 1px solid #f1f5f9;">
    <div class="p-3 border-bottom d-flex justify-content-between align-items-center" style="background-color: #f8fafc;">
        <span class="font-weight-bold text-primary" style="font-size: 1.1rem; letter-spacing: -0.5px;">@Code</span>
        <span class="badge text-secondary border bg-white rounded-pill px-2 py-1" style="font-size: 0.75rem;">@Semester</span>
    </div>
    <div class="card-body p-3 d-flex flex-column justify-content-between" style="min-height: 160px;">
        <div>
            <h6 class="card-title font-weight-bold mb-1 text-dark" style="line-height: 1.4;">@Title</h6>
            <p class="text-muted small mb-3">Academic Unit Weight: <strong class="text-dark">@Credits Hours</strong></p>
        </div>

        @if (!IsOpen)
        {
            <div class="d-flex align-items-center justify-content-between pt-2 border-top">
                <span class="text-danger small font-weight-bold d-flex align-items-center">🔒 Allocation Full</span>
                <button class="btn btn-sm btn-secondary disabled opacity-50 px-3" disabled>Locked</button>
            </div>
        }
        else
        {
            <div class="d-flex align-items-center justify-content-between pt-2 border-top">
                <span class="text-success small font-weight-bold d-flex align-items-center">🟢 Active Queue</span>
                <button class="btn btn-sm btn-outline-primary px-3 rounded-pill font-weight-bold" @onclick="DispatchRegistration">Select Unit</button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Code { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public int Credits { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<string> OnRegister { get; set; }
    
    [CascadingParameter] public string Semester { get; set; } = "";

    private async Task DispatchRegistration()
    {
        await OnRegister.InvokeAsync(Code);
    }
}