@page "/"

<PageTitle>GCTU Campus Companion - Home</PageTitle>

<div class="p-5 mb-4 rounded-4 shadow-sm text-white" style="background: linear-gradient(135deg, #0A192F 0%, #1E3A8A 100%);">
    <div class="container-fluid py-2">
        <span class="badge bg-primary text-uppercase tracking-wider px-3 py-2 mb-3" style="font-size: 0.8rem; font-weight: 600;">
            Department Portal
        </span>
        <h1 class="display-5 font-weight-bold" style="letter-spacing: -1px;">
            GCTU Computer Engineering Department
        </h1>
        <p class="col-md-9 fs-5 text-white-50 mb-0">
            Welcome to your internal academic companion application. Use this central hub to verify student profiles, analyze course tracking sheets, calculate grading metrics, and process semester registration queues.
        </p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12">
        <h5 class="text-secondary font-weight-bold mb-3 d-flex align-items-center">
            <span class="me-2">📁</span> Active Application Modules
        </h5>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100 border-0 shadow-sm p-3 rounded-3 bg-white border-top border-primary border-4" style="border-top-width: 4px !important;">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <div class="fs-3 mb-2">🪪</div>
                    <h6 class="font-weight-bold text-dark mb-1">Student ID Card</h6>
                    <p class="text-muted small">Verify active identity metrics, status bands, and programmatic department alignments.</p>
                </div>
                <a href="id-card" class="btn btn-sm btn-outline-primary w-100 rounded-pill mt-2">Launch Card</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100 border-0 shadow-sm p-3 rounded-3 bg-white border-top border-primary border-4" style="border-top-width: 4px !important;">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <div class="fs-3 mb-2">📜</div>
                    <h6 class="font-weight-bold text-dark mb-1">Curriculum Inventory</h6>
                    <p class="text-muted small">Review complete registered course tables alongside core unit classification weights.</p>
                </div>
                <a href="courses" class="btn btn-sm btn-outline-primary w-100 rounded-pill mt-2">Open Directory</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100 border-0 shadow-sm p-3 rounded-3 bg-white border-top border-success border-4" style="border-top-width: 4px !important;">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <div class="fs-3 mb-2">📊</div>
                    <h6 class="font-weight-bold text-dark mb-1">Assessment Engine</h6>
                    <p class="text-muted small">Process continuous assessment and final exam ratios instantly using dynamic pipelines.</p>
                </div>
                <a href="grade-tool" class="btn btn-sm btn-outline-success w-100 rounded-pill mt-2">Run Calculator</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100 border-0 shadow-sm p-3 rounded-3 bg-white border-top border-success border-4" style="border-top-width: 4px !important;">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <div class="fs-3 mb-2">🗳️</div>
                    <h6 class="font-weight-bold text-dark mb-1">Registration Hub</h6>
                    <p class="text-muted small">Manage stateful cascading course distributions via multi-component event queues.</p>
                </div>
                <a href="registration" class="btn btn-sm btn-outline-success w-100 rounded-pill mt-2">Manage Board</a>
            </div>
        </div>
    </div>
</div>

<div class="p-4 rounded-3 bg-white shadow-sm border" style="border-left: 4px solid #0A192F !important;">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h6 class="font-weight-bold mb-1 text-dark">Deployment Status Architecture</h6>
            <p class="text-muted small mb-0">
                This environment is currently powered by <strong>.NET 10 (LTS)</strong>, running distributed Blazor unified interactive rendering processes mapped directly to GitHub repository branches.
            </p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <span class="badge bg-light text-dark border px-3 py-2 rounded-3">
                🟢 System Online
            </span>
        </div>
    </div>
</div>