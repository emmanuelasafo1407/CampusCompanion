@page "/grade-tool"
@rendermode InteractiveServer

<div class="card shadow-lg border-0 mx-auto" style="max-width: 550px; border-radius: 16px; background: #ffffff; overflow: hidden;">
    <div style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); padding: 25px; color: #ffffff;">
        <h4 class="margin-0" style="font-weight: 700;">GCTU Performance Assessment Calculator</h4>
        <p class="text-white-50 small mb-0">Weight Distribution Formula: 40% Continuous Assessment + 60% Final Exam</p>
    </div>
    
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label font-weight-bold" style="color: #475569;">CA Score (0 - 100)</label>
                <div class="input-group">
                    <span class="input-group-text bg-light">📝</span>
                    <input type="number" class="form-control" @bind="caScore" @bind:event="oninput" min="0" max="100" />
                </div>
            </div>
            <div class="col-md-6">
                <label class="form-label font-weight-bold" style="color: #475569;">Final Exam Score (0 - 100)</label>
                <div class="input-group">
                    <span class="input-group-text bg-light">🎓</span>
                    <input type="number" class="form-control" @bind="examScore" @bind:event="oninput" min="0" max="100" />
                </div>
            </div>
        </div>

        <div class="mt-4 p-4 rounded-3 text-center" style="background: #f8fafc; border: 1px solid #e2e8f0;">
            <span class="text-muted text-uppercase tracking-wider small font-weight-bold">Calculated Weight Mark</span>
            <h1 class="display-4 font-weight-bold my-2" style="color: #1e3a8a;">@FinalMark<span style="font-size: 1.5rem; color: #64748b;">/100</span></h1>
            
            <div class="d-inline-block px-4 py-2 rounded-pill font-weight-bold shadow-sm mt-2" style="@GetBandStyle(FinalMark)">
                Classification: @GetClassification(FinalMark)
            </div>
        </div>
    </div>
</div>

@code {
    private double caScore = 0;
    private double examScore = 0;

    private double FinalMark => (caScore * 0.4) + (examScore * 0.6);

    private string GetClassification(double mark) => mark switch {
        >= 70 => "First Class",
        >= 60 => "Second Upper",
        >= 50 => "Second Lower",
        >= 40 => "Pass",
        _ => "Fail"
    };

    private string GetBandStyle(double mark) => mark switch {
        >= 70 => "background-color: #d1fae5; color: #065f46;",
        >= 60 => "background-color: #dbeafe; color: #1e40af;",
        >= 50 => "background-color: #fef3c7; color: #92400e;",
        >= 40 => "background-color: #f1f5f9; color: #334155;",
        _ => "background-color: #fee2e2; color: #991b1b;"
    };
}