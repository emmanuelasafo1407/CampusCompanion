@page "/id-card"
<PageTitle>Student ID</PageTitle>

<div class="card shadow-lg mx-auto" style="width: 24rem; border: none; border-radius: 16px; overflow: hidden; background: #ffffff;">
    <div style="background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%); padding: 25px; text-align: center; position: relative;">
        <div style="position: absolute; top: 15px; right: 15px; width: 12px; height: 12px; background-color: #10b981; border-radius: 50%; shadow: 0 0 8px #10b981;"></div>
        <h5 style="color: #f8fafc; margin: 0; font-weight: 700; letter-spacing: 1px;">GCTU STUDENT ID</h5>
        <span style="color: #93c5fd; font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.5px;">Computer Engineering Dept</span>
    </div>
    
    <div class="card-body p-4" style="color: #334155;">
        <div class="d-flex align-items-center mb-4">
            <div style="width: 70px; height: 70px; background: #f1f5f9; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 15px; border: 2px solid #e2e8f0;">
                <span style="font-size: 2rem; color: #64748b;">👤</span>
            </div>
            <div>
                <h4 style="margin: 0; font-weight: 600; color: #0f172a; font-size: 1.25rem;">@fullName</h4>
                <span style="font-size: 0.85rem; color: #64748b;">ID: @indexNumber</span>
            </div>
        </div>

        <div style="background-color: #f8fafc; padding: 15px; border-radius: 10px; border: 1px solid #f1f5f9;">
            <div class="mb-2"><span style="color: #64748b; font-size: 0.85rem;">Programme</span><br/><strong style="color: #334155;">@programme</strong></div>
            <div><span style="color: #64748b; font-size: 0.85rem;">Academic Level</span><br/><strong style="color: #334155;">Level @level</strong></div>
        </div>

        @if (isFinalYear)
        {
            <div class="mt-3 text-center" style="background: linear-gradient(90deg, #fef08a 0%, #fde047 100%); color: #713f12; font-weight: 700; padding: 8px; border-radius: 8px; font-size: 0.9rem; box-shadow: 0 2px 4px rgba(253,224,71,0.3);">
                ✨ Final-Year Student Status
            </div>
        }
    </div>
    
    <div class="card-footer py-3 text-center" style="background-color: #f8fafc; border-top: 1px solid #f1f5f9; font-size: 0.8rem; color: #64748b;">
        📧 Official Contact: info@@gctu.edu.gh
    </div>
</div>

@code {
    private string fullName = "Emmanuel Asafo";
    private string indexNumber = "1706547871";
    private string programme = "BSc Computer Engineering";
    private int level = 400;
    private bool isFinalYear = true; // Set to true if the student is in their final year
}